# ==================== API PROVIDER ====================
# Выберите провайдера: "proxy" (Российский Proxy API) или "openai" (OpenAI)
API_PROVIDER=proxy

# ==================== РОССИЙСКИЙ PROXY API ====================
# URL российского Proxy API (https://proxyapi.ru)
PROXY_API_URL=https://api.proxyapi.ru/openai/v1

# API ключ для Proxy API (получить на https://console.proxyapi.ru/keys)
PROXY_API_KEY=your_proxy_api_key_here

# ==================== OPENAI API (ОПЦИОНАЛЬНО) ====================
# OpenAI API ключ (используется только если API_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# ==================== МОДЕЛИ ====================
# Модель для эмбеддингов
EMBEDDING_MODEL=text-embedding-3-small

# Модель для чата
CHAT_MODEL=gpt-3.5-turbo

# ==================== ПАРАМЕТРЫ ====================
# Размер чанка в символах
CHUNK_SIZE=500

# Overlap между чанками в символах
CHUNK_OVERLAP=100

# Количество релевантных чанков для поиска
TOP_K=5

# Путь к данным
DATA_DIR=./data
